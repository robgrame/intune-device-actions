      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), '2024-10-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('roleMonitoringReader')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix')))]"
      ]
    },
    {
