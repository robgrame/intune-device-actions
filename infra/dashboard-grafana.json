      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), 'Reader')]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), '2024-10-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('roleReader')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix')))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ServiceBus/namespaces', parameters('sbNamespaceName'))]",
      "name": "[guid(resourceId('Microsoft.ServiceBus/namespaces', parameters('sbNamespaceName')), resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), 'MonitoringReader')]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), '2024-10-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('roleMonitoringReader')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix')))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]",
      "name": "[guid(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), 'MonitoringReader')]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), '2024-10-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('roleMonitoringReader')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix')))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('ledgerStorageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('ledgerStorageAccountName')), resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), 'StorageBlobDataReader')]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), '2024-10-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('roleStorageBlobDataReader')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix')))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix')))]",
      "name": "[guid(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), parameters('operatorObjectId'), 'GrafanaAdmin')]",
      "properties": {
        "principalId": "[parameters('operatorObjectId')]",
        "principalType": "User",
        "roleDefinitionId": "[variables('roleGrafanaAdmin')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix')))]"
      ]
    }
  ],
  "outputs": {
