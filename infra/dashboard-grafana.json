{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "4470491786473383331"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "idactions",
      "minLength": 3,
      "maxLength": 12,
      "metadata": {
        "description": "Name prefix used to align with the existing app stamp. Keep the same prefix as main.bicep."
      }
    },
    "suffix": {
      "type": "string",
      "defaultValue": "dev",
      "metadata": {
        "description": "Suffix to distinguish the dev/prod stamp. Match the suffix used by your *-<suffix> Function Apps."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Managed Grafana is not available in every region — westeurope, northeurope, italynorth (preview) all work; check current availability if you hit a deployment error."
      }
    },
    "operatorObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID (oid) of the operator who should receive Grafana Admin on this instance. Required."
      }
    },
    "sbNamespaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Service Bus namespace whose queues feed the dashboard panels. Used only for the role-assignment scope."
      }
    },
    "appInsightsName": {
      "type": "string",
      "metadata": {
        "description": "Application Insights component name backing the KQL panels."
      }
    },
    "ledgerStorageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account hosting the action-ledger blob container."
      }
    },
    "grafanaSku": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": [
        "Standard"
      ],
      "metadata": {
        "description": "SKU for the managed Grafana instance. Azure currently only supports Standard."
      }
    }
  },
  "variables": {
    "roleMonitoringReader": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '43d0d8ad-25c7-4714-9337-8ba259a9fe05')]",
    "roleReader": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]",
    "roleStorageBlobDataReader": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '2a2b9908-6ea1-4ae2-8e65-a410df84e7d1')]",
    "roleGrafanaAdmin": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '22926164-76b3-42b3-bc55-97df8dab3e41')]"
  },
  "resources": [
