      "type": "string",
      "value": "[format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))]"
    },
    "grafanaEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), '2024-10-01').endpoint]"
    },
    "grafanaPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Dashboard/grafana', format('{0}-grafana-{1}', parameters('namePrefix'), parameters('suffix'))), '2024-10-01', 'full').identity.principalId]"
